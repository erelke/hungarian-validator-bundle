{
    "name": "erelke/hungarian-validator-bundle",
    "description": "Symfony bundle a Magyarorszagon hasznalt hivatalos adatok (ugy mint: szemelyi szam, adoazonosito jel...) validalasara",
    "homepage": "https://github.com/erelke/hungarian-validator-bundle",
    "type": "symfony-bundle",
    "license": "MIT",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/erelke/hungarian-validator-bundle"
        }
    ],
    "authors": [
        {
            "name": "Elemer Eross",
            "email": "eross@korona.info.hu"
        },
        {
            "name": "Peter Simon",
            "email": "simonpepe@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/validator": "^5.4|^6.4",
        "symfony/property-access": "^5.4|^6.4",
        "symfony/config": "^5.4|^6.4",
        "symfony/dependency-injection": "^5.4|^6.4",
        "symfony/http-kernel": "^5.4|^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Erelke\\HungarianValidatorBundle\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Erelke\\HungarianValidatorBundle\\Tests\\": "Tests/"
        }
    }
}
